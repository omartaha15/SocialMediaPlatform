@model SocialMedia.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h2 class="mb-4">Welcome Back</h2>

<form asp-action="Login" method="post" id="loginForm">

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="form-group form-check">
        <input asp-for="RememberMe" class="form-check-input" />
        <label asp-for="RememberMe" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary btn-lg mt-3 w-100">Login</button>
</form>

<div class="mt-3 text-center">
    <p>Don't have an account? <a asp-action="Register" asp-controller="Account" class="btn btn-link">Register</a></p>
</div>

<style>
    input.input-validation-error, select.input-validation-error, textarea.input-validation-error {
        border: 2px solid #dc3545;
        background-color: #f8d7da;
    }

    input.valid, select.valid, textarea.valid {
        border: 2px solid #28a745;
        background-color: #d4edda;
    }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 2px;
    }

    .btn-lg {
        font-size: 1.1rem;
        padding: 0.75rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $("#loginForm").validate({
                highlight: function (element) {
                    $(element).removeClass("valid").addClass("input-validation-error");
                },
                unhighlight: function (element) {
                    $(element).removeClass("input-validation-error").addClass("valid");
                },
                errorElement: "span",
                errorClass: "text-danger small"
            });
        });
    </script>
}
@model SocialMedia.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon">
                <i class="fas fa-user-lock" style="color:white;"></i>
            </div>
            <h2>Welcome Back</h2>
            <p>Sign in to continue to SocialConnect</p>
        </div>

        <form asp-action="Login" method="post" id="loginForm">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
            }

            <div class="form-group">
                <label asp-for="Email"><i class="fas fa-envelope me-1"></i> Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"><i class="fas fa-lock me-1"></i> Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-group form-check d-flex align-items-center mt-2">
                <input asp-for="RememberMe" class="form-check-input me-2" />
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 mt-3" id="loginBtn">
                <i class="fas fa-sign-in-alt me-2"></i> Sign In
            </button>
        </form>

        <div class="auth-footer">
            <p>Don't have an account? <a asp-action="Register" asp-controller="Account" class="btn-link">Create one</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $("#loginForm").validate({
                highlight: function (element) {
                    $(element).removeClass("valid").addClass("input-validation-error");
                },
                unhighlight: function (element) {
                    $(element).removeClass("input-validation-error").addClass("valid");
                },
                errorElement: "span",
                errorClass: "text-danger small"
            });
        });
    </script>
}
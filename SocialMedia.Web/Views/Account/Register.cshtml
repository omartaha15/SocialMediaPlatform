@model SocialMedia.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<h2 class="mb-4">Create Your Account</h2>

<form asp-action="Register" method="post" enctype="multipart/form-data" id="registerForm">
    <div class="form-group">
        <label asp-for="UserName"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="ConfirmPassword"></label>
        <input asp-for="ConfirmPassword" class="form-control" type="password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="Bio"></label>
        <textarea asp-for="Bio" class="form-control"></textarea>
        <span asp-validation-for="Bio" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="Location"></label>
        <input asp-for="Location" class="form-control" />
        <span asp-validation-for="Location" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="DateOfBirth"></label>
        <input asp-for="DateOfBirth" class="form-control" type="date" />
        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="Gender"></label>
        <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<SocialMedia.Domain.Enums.Gender>()">
            <option value="">Select Gender</option>
        </select>
        <span asp-validation-for="Gender" class="text-danger small"></span>
    </div>

    <div class="form-group">
        <label asp-for="ProfileImage">Profile Image</label>
        <input asp-for="ProfileImage" type="file" class="form-control" />
        <span asp-validation-for="ProfileImage" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg mt-3">Register</button>
</form>

<div class="mt-3">
    <p>Already have an account? <a asp-action="Login" asp-controller="Account" class="btn btn-link">Login</a></p>
</div>

<style>
    /* الأخطاء باللون الأحمر */
    input.input-validation-error, select.input-validation-error, textarea.input-validation-error {
        border: 2px solid #dc3545;
        background-color: #f8d7da;
    }

    /* الحقول الصحيحة باللون الأخضر */
    input.valid, select.valid, textarea.valid {
        border: 2px solid #28a745;
        background-color: #d4edda;
    }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 2px;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $("#registerForm").validate({
                highlight: function (element) {
                    $(element).removeClass("valid").addClass("input-validation-error");
                },
                unhighlight: function (element) {
                    $(element).removeClass("input-validation-error").addClass("valid");
                },
                errorElement: "span",
                errorClass: "text-danger small"
            });
        });
    </script>
}
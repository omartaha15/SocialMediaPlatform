@using SocialMedia.Domain.Entities
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Friends";
    var pendingRequests = ViewBag.PendingRequests as IEnumerable<ApplicationUser> ?? new List<ApplicationUser>();
    var friendsCount = ViewBag.FriendsCount ?? 0;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>Your Friends (@friendsCount)</h2>
            <hr />

            @if (!Model.Any())
            {
                <p class="text-muted">You do not have any friends yet.</p>
            }
            else
            {
                <div class="list-group mb-4">
                    @foreach (var friend in Model)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <img src="@friend.ProfilePictureUrl" alt="@friend.UserName" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <h5 class="mb-0">@friend.UserName</h5>
                                    <small class="text-muted">@friend.Email</small>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <a class="btn btn-primary btn-sm"
                                   asp-controller="Messaging"
                                   asp-action="Chat"
                                   asp-route-otherUserId="@friend.Id"
                                   asp-route-otherUserName="@friend.UserName"
                                   asp-route-otherUserProfilePicture="@friend.ProfilePictureUrl">Message</a>
                                <!-- Remove Friend Button -->
                                <form asp-controller="Friendship" asp-action="RemoveFriend" method="post" class="d-inline">
                                    <input type="hidden" name="friendId" value="@friend.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Remove Friend</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-4">
            <h4>Pending Requests (@pendingRequests.Count())</h4>
            <div class="card">
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (!pendingRequests.Any())
                        {
                            <li class="list-group-item text-muted">No pending requests.</li>
                        }
                        else
                        {
                            @foreach (var sender in pendingRequests)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <img src="@sender.ProfilePictureUrl" alt="@sender.UserName" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                        <span>@sender.UserName</span>
                                    </div>
                                    <form asp-controller="Friendship" asp-action="AcceptRequest" method="post" class="d-inline">
                                        <input type="hidden" name="senderId" value="@sender.Id" />
                                        <button type="submit" class="btn btn-success btn-sm">Accept</button>
                                    </form>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@using SocialMedia.Application.DTOs.Pagination
@using SocialMedia.Application.DTOs.ProfileDTOs
@model PaginatedList<UserSuggestionDto>

@{
    ViewData["Title"] = "Friend Suggestions";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h2>Suggest Friends</h2>
            <hr />

            @if (!Model.Items.Any())
            {
                <div class="alert alert-info">No new friend suggestions at this time.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var suggestion in Model.Items)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <img src="@suggestion.ProfilePictureUrl" alt="@suggestion.UserName" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <h5 class="mb-0">@suggestion.UserName</h5>
                                    @if (!string.IsNullOrEmpty(suggestion.Location))
                                    {
                                        <small class="text-muted d-block">@suggestion.Location</small>
                                    }
                                    @if(suggestion.MutualFriendsCount > 0)
                                    {
                                        <small class="text-primary mt-1 d-block"><i class="fas fa-user-friends"></i> @suggestion.MutualFriendsCount mutual friends</small>
                                    }
                                </div>
                            </div>
                            <!-- Actions -->
                            <div class="d-flex gx-2">
                                <form asp-controller="Friendship" asp-action="SendRequest" method="post" class="d-inline ms-2">
                                    <input type="hidden" name="receiverId" value="@suggestion.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm px-3">Add Friend</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination Controls -->
                <div class="mt-4 d-flex justify-content-between align-items-center">
                    <div>
                        Page @Model.PageIndex of @Model.TotalPages
                    </div>
                    <div>
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Suggestions" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn btn-outline-primary btn-sm">&laquo; Previous</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm" disabled>&laquo; Previous</button>
                        }

                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Suggestions" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn btn-outline-primary btn-sm">Next &raquo;</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm" disabled>Next &raquo;</button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>


@using SocialMedia.Domain.Entities
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Friend Suggestions";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h2>Suggest Friends</h2>
            <hr />

            @if (!Model.Any())
            {
                <div class="alert alert-info">No new friend suggestions at this time.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var suggestion in Model)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <img src="@suggestion.ProfilePictureUrl" alt="@suggestion.UserName" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <h5 class="mb-0">@suggestion.UserName</h5>
                                    <small class="text-muted">@suggestion.Location</small>
                                </div>
                            </div>
                            <!-- Actions -->
                            <div class="d-flex gx-2">
                                <form asp-controller="Friendship" asp-action="SendRequest" method="post" class="d-inline ms-2">
                                    <input type="hidden" name="receiverId" value="@suggestion.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm px-3">Add Friend</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

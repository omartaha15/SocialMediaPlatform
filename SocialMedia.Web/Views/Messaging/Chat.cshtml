@model SocialMedia.Web.ViewModels.Chat.ChatViewModel

@{
    ViewData["Title"] = "Chat with " + Model.OtherUserName;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<style>
    .chat-wrapper {
        max-width: 750px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 130px);
    }

    .chat-header {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
        padding: 0.85rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

    .chat-header img {
        width: 40px; height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--accent);
    }

    .chat-header-name {
        font-weight: 600;
        color: var(--text-primary);
    }

    .chat-back {
        margin-left: auto;
        color: var(--text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        transition: var(--transition);
    }

    .chat-back:hover { color: var(--accent); }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.25rem;
        background: var(--bg-secondary);
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .bubble-row {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .bubble-row.sent { flex-direction: row-reverse; }

    .bubble {
        max-width: 65%;
        padding: 0.6rem 0.95rem;
        border-radius: var(--radius-lg);
        font-size: 0.9rem;
        line-height: 1.45;
        word-break: break-word;
    }

    .bubble.sent {
        background: var(--gradient-primary);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .bubble.received {
        background: var(--bg-card);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
        border-bottom-left-radius: 4px;
    }

    .bubble-time {
        font-size: 0.68rem;
        color: var(--text-muted);
        flex-shrink: 0;
        margin-bottom: 4px;
    }

    .chat-input-area {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-top: none;
        border-radius: 0 0 var(--radius-md) var(--radius-md);
        padding: 0.85rem 1rem;
        display: flex;
        gap: 0.65rem;
        align-items: center;
    }

    #msgInput {
        flex: 1;
        background: var(--bg-input);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        color: var(--text-primary);
        padding: 0.6rem 1.1rem;
        font-size: 0.9rem;
        outline: none;
        transition: var(--transition);
    }

    #msgInput:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-glow);
    }

    #sendBtn {
        width: 40px; height: 40px;
        border-radius: 50%;
        background: var(--gradient-primary);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: var(--transition);
    }

    #sendBtn:hover {
        transform: scale(1.08);
        box-shadow: var(--shadow-glow);
    }
</style>

<div class="chat-wrapper">
    <!-- Header -->
    <div class="chat-header">
        <img src="@(Model.OtherUserProfilePicture ?? "/images/user.jpg")" alt="@Model.OtherUserName" />
        <span class="chat-header-name">@Model.OtherUserName</span>
        <a class="chat-back" asp-controller="Messaging" asp-action="Index">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="messagesContainer">
        @foreach (var msg in Model.History)
        {
            var isSent = msg.SenderId == currentUserId;
            <div class="bubble-row @(isSent ? "sent" : "received")">
                <span class="bubble-time">@msg.CreatedAt.ToString("HH:mm")</span>
                <div class="bubble @(isSent ? "sent" : "received")">@msg.Content</div>
            </div>
        }
    </div>

    <!-- Input -->
    <div class="chat-input-area">
        <input type="text" id="msgInput" placeholder="Type a message..." autocomplete="off" />
        <button id="sendBtn" title="Send">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const currentUserId  = "@currentUserId";
    const otherUserId    = "@Model.OtherUserId";
    const otherUserName  = "@Model.OtherUserName";
    const senderName     = "@User.Identity?.Name";
    const token          = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        ?? "@Html.AntiForgeryToken()";

    const container = document.getElementById("messagesContainer");
    const input     = document.getElementById("msgInput");
    const sendBtn   = document.getElementById("sendBtn");

    // ── Scroll to bottom ──────────────────────────────────────────────────────
    function scrollToBottom() {
        container.scrollTop = container.scrollHeight;
    }
    scrollToBottom();

    // ── Append bubble ─────────────────────────────────────────────────────────
    function appendBubble(senderId, content, sentAt) {
        const isSent = senderId === currentUserId;
        const time   = new Date(sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        const row = document.createElement("div");
        row.className = `bubble-row ${isSent ? "sent" : "received"}`;
        row.innerHTML = `
            <span class="bubble-time">${time}</span>
            <div class="bubble ${isSent ? "sent" : "received"}">${escapeHtml(content)}</div>`;

        container.appendChild(row);
        scrollToBottom();
    }

    function escapeHtml(text) {
        return text.replace(/&/g,"&amp;").replace(/</g,"&lt;")
                   .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    // ── SignalR ───────────────────────────────────────────────────────────────
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveDirectMessage", (data) => {
        // only render if this message belongs to this conversation
        if (data.senderId === otherUserId || data.senderId === currentUserId) {
            appendBubble(data.senderId, data.content, data.sentAt);
        }
    });

    connection.start().catch(err => console.error("SignalR error:", err));

    // ── Send ──────────────────────────────────────────────────────────────────
    async function sendMessage() {
        const content = input.value.trim();
        if (!content) return;
        input.value = "";

        const formData = new FormData();
        formData.append("receiverId", otherUserId);
        formData.append("content",    content);
        formData.append("__RequestVerificationToken", getAntiForgeryToken());

        // 1. Save to DB
        await fetch("/Messaging/SendMessage", { method: "POST", body: formData });

        // 2. Push real-time via hub (hub echoes back to sender too)
        await connection.invoke("SendDirectMessage", otherUserId, senderName, content)
            .catch(err => console.error(err));
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
    }

    sendBtn.addEventListener("click", sendMessage);
    input.addEventListener("keydown", e => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
</script>
@Html.AntiForgeryToken()
}

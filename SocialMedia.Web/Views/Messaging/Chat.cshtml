
@model SocialMedia.Web.ViewModels.Chat.ChatViewModel

@{
    ViewData["Title"] = "Chat with " + Model.OtherUserName;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<style>
    .chat-wrapper {
        max-width: 750px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 130px);
    }

    .chat-header {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
        padding: 0.85rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

        .chat-header img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--accent);
        }

    .chat-header-info {
        display: flex;
        flex-direction: column;
    }

    .chat-header-name {
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.2;
    }

    .online-status {
        font-size: 0.72rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        margin-top: 1px;
    }

    .online-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

        .online-dot.online {
            background: #22c55e;
            box-shadow: 0 0 0 2px rgba(34,197,94,0.25);
        }

        .online-dot.offline {
            background: var(--text-muted);
        }

    .typing-indicator {
        display: none;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.85rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-style: italic;
    }

    .typing-dots span {
        display: inline-block;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--text-muted);
        animation: typingBounce 1.2s infinite;
        margin: 0 1px;
    }

        .typing-dots span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dots span:nth-child(3) {
            animation-delay: 0.4s;
        }


    .chat-back {
        margin-left: auto;
        color: var(--text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        transition: var(--transition);
    }

        .chat-back:hover {
            color: var(--accent);
        }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.25rem;
        background: var(--bg-secondary);
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .bubble-row {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
    }

        .bubble-row.sent {
            flex-direction: row-reverse;
        }

    .bubble {
        max-width: 65%;
        padding: 0.6rem 0.95rem;
        border-radius: var(--radius-lg);
        font-size: 0.9rem;
        line-height: 1.45;
        word-break: break-word;
    }

        .bubble.sent {
            background: var(--gradient-primary);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .bubble.received {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
            border-bottom-left-radius: 4px;
        }

    .bubble-time {
        font-size: 0.68rem;
        color: var(--text-muted);
        flex-shrink: 0;
        margin-bottom: 4px;
    }

    .chat-input-area {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-top: none;
        border-radius: 0 0 var(--radius-md) var(--radius-md);
        padding: 0.85rem 1rem;
        display: flex;
        gap: 0.65rem;
        align-items: center;
    }

    #msgInput {
        flex: 1;
        background: var(--bg-input);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        color: var(--text-primary);
        padding: 0.6rem 1.1rem;
        font-size: 0.9rem;
        outline: none;
        transition: var(--transition);
    }

        #msgInput:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

    #sendBtn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--gradient-primary);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: var(--transition);
    }

        #sendBtn:hover {
            transform: scale(1.08);
            box-shadow: var(--shadow-glow);
        }
</style>

<div class="chat-wrapper">
    <!-- Header -->
    <div class="chat-header">
        <img src="@(Model.OtherUserProfilePicture ?? "/images/user.jpg")" alt="@Model.OtherUserName" />
        <div class="chat-header-info">
            <span class="chat-header-name">@Model.OtherUserName</span>
            <span class="online-status" id="onlineStatus">
                <span class="online-dot offline" id="onlineDot"></span>
                <span id="onlineLabel" style="color: var(--text-muted);">Offline</span>
            </span>
        </div>
        <a class="chat-back" asp-controller="Messaging" asp-action="Index">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="messagesContainer">
        @foreach (var msg in Model.History)
        {
            var isSent = msg.SenderId == currentUserId;
            <div class="bubble-row @(isSent ? "sent" : "received")">
                <span class="bubble-time">@msg.CreatedAt.ToString("HH:mm")</span>
                <div class="bubble @(isSent ? "sent" : "received")">@msg.Content</div>
            </div>
        }
    </div>

    <!-- Typing indicator -->
    <div class="typing-indicator" id="typingIndicator">
        <span>@Model.OtherUserName is typing</span>
        <div class="typing-dots"><span></span><span></span><span></span></div>
    </div>

    <!-- Input -->
    <div class="chat-input-area">
        @Html.AntiForgeryToken()
        <input type="text" id="msgInput" placeholder="Type a message..." autocomplete="off" />
        <button id="sendBtn" title="Send">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const currentUserId  = "@currentUserId";
        const otherUserId    = "@Model.OtherUserId";
        const otherUserName  = "@Model.OtherUserName";
        const senderName     = "@User.Identity?.Name";

        const container = document.getElementById("messagesContainer");
        const input     = document.getElementById("msgInput");
        const sendBtn   = document.getElementById("sendBtn");

        // ── Scroll to bottom ──────────────────────────────────────────────────────
        function scrollToBottom() {
            container.scrollTop = container.scrollHeight;
        }
        scrollToBottom();

        // ── Append bubble ─────────────────────────────────────────────────────────
        function appendBubble(senderId, content, sentAt) {
            const isSent = senderId === currentUserId;
            const time   = new Date(sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            const row = document.createElement("div");
            row.className = `bubble-row ${isSent ? "sent" : "received"}`;
            row.innerHTML = `
                <span class="bubble-time">${time}</span>
                <div class="bubble ${isSent ? "sent" : "received"}">${escapeHtml(content)}</div>`;

            container.appendChild(row);
            scrollToBottom();
        }

        function escapeHtml(text) {
            return text.replace(/&/g,"&amp;").replace(/</g,"&lt;")
                       .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
        }

        // ── SignalR ───────────────────────────────────────────────────────────────
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveDirectMessage", (data) => {
            // only render if this message belongs to this conversation
            if (data.senderId === otherUserId || data.senderId === currentUserId) {
                appendBubble(data.senderId, data.content, data.sentAt);
            }
        });

        connection.start().catch(err => console.error("SignalR error:", err));

        // ── Send ──────────────────────────────────────────────────────────────────
        async function sendMessage() {
            const content = input.value.trim();
            if (!content) return;
            input.value = "";

            const formData = new FormData();
            formData.append("receiverId", otherUserId);
            formData.append("content",    content);
            formData.append("__RequestVerificationToken", getAntiForgeryToken());

            // Save to DB — controller broadcasts via SignalR to both users, so we
            // do NOT manually append a bubble here (that would cause a double render).
            await fetch("/Messaging/SendMessage", { method: "POST", body: formData });

            // Update the navbar unread badge (in case receiver had open conversations)
            if (typeof refreshMsgBadge === 'function') refreshMsgBadge();
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
        }

        sendBtn.addEventListener("click", sendMessage);
        input.addEventListener("keydown", e => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); } });

        // ── Online status ────────────────────────────────────────────────────
        const onlineDot   = document.getElementById("onlineDot");
        const onlineLabel = document.getElementById("onlineLabel");
        function setOnline(isOnline) {
            onlineDot.className     = `online-dot ${isOnline ? 'online' : 'offline'}`;
            onlineLabel.textContent = isOnline ? 'Online' : 'Offline';
            onlineLabel.style.color = isOnline ? '#22c55e' : 'var(--text-muted)';
        }
        async function refreshOnlineStatus() {
            try {
                const res  = await fetch(`/Messaging/IsOnline?userId=${encodeURIComponent(otherUserId)}`);
                const data = await res.json();
                setOnline(data.online);
            } catch { /* ignore */ }
        }
        refreshOnlineStatus();
        setInterval(refreshOnlineStatus, 20000);

        // ── Typing indicator ──────────────────────────────────────────────────
        const typingIndicator = document.getElementById("typingIndicator");
        let typingTimer;
        let isTyping = false;
        function showTyping() { typingIndicator.style.display = 'flex'; container.scrollTop = container.scrollHeight; }
        function hideTyping() { typingIndicator.style.display = 'none'; }

        // Wire up typing events on the existing SignalR connection
        connection.on("UserTyping",        (id) => { if (id === otherUserId) showTyping(); });
        connection.on("UserStoppedTyping", (id) => { if (id === otherUserId) hideTyping(); });
        connection.on("UserOnlineStatus",  (id, online) => { if (id === otherUserId) setOnline(online); });

        // Also auto mark-as-read and refresh badge when message arrives from other user
        connection.on("ReceiveDirectMessage_Extras", () => {}); // placeholder, handled below via patch
        const _origReceive = connection.methods["receivedirectmessage"]?.[0];
        // Patch: after original handler runs, also mark-read if incoming
        connection.off("ReceiveDirectMessage");
        connection.on("ReceiveDirectMessage", (data) => {
            if (data.senderId === otherUserId || data.senderId === currentUserId) {
                hideTyping();
                appendBubble(data.senderId, data.content, data.sentAt);
                if (data.senderId === otherUserId) {
                    const fd = new FormData();
                    fd.append("otherUserId", otherUserId);
                    fd.append("__RequestVerificationToken", getAntiForgeryToken());
                    fetch("/Messaging/MarkRead", { method: "POST", body: fd });
                    if (typeof refreshMsgBadge === 'function') refreshMsgBadge();
                }
            }
        });

        input.addEventListener("input", () => {
            if (!isTyping) {
                isTyping = true;
                connection.invoke("StartTyping", otherUserId).catch(() => {});
            }
            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => {
                isTyping = false;
                connection.invoke("StopTyping", otherUserId).catch(() => {});
            }, 2000);
        });

        // Clear typing on send
        const _origSend = sendMessage;
        // Already defined above — just add cleanup via original send
        const _wrappedSend = async () => {
            if (isTyping) {
                isTyping = false;
                clearTimeout(typingTimer);
                connection.invoke("StopTyping", otherUserId).catch(() => {});
            }
            await _origSend();
        };
        sendBtn.removeEventListener("click", sendMessage);
        sendBtn.addEventListener("click", _wrappedSend);
        input.removeEventListener("keydown", null);
        input.addEventListener("keydown", e => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); _wrappedSend(); } });
    </script>
}

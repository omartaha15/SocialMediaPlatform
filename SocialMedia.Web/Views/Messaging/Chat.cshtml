
@model SocialMedia.Web.ViewModels.Chat.ChatViewModel

@{
    ViewData["Title"] = "Chat with " + Model.OtherUserName;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<style>
    .chat-wrapper {
        max-width: 750px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 130px);
    }

    .chat-header {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
        padding: 0.85rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

        .chat-header img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--accent);
        }

    .chat-header-info {
        display: flex;
        flex-direction: column;
    }

    .chat-header-name {
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.2;
    }

    .online-status {
        font-size: 0.72rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        margin-top: 1px;
    }

    .online-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

        .online-dot.online {
            background: #22c55e;
            box-shadow: 0 0 0 2px rgba(34,197,94,0.25);
        }

        .online-dot.offline {
            background: var(--text-muted);
        }

    .typing-indicator {
        display: none;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.85rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-style: italic;
    }

    .typing-dots span {
        display: inline-block;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--text-muted);
        animation: typingBounce 1.2s infinite;
        margin: 0 1px;
    }

        .typing-dots span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dots span:nth-child(3) {
            animation-delay: 0.4s;
        }


    .chat-back {
        margin-left: auto;
        color: var(--text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        transition: var(--transition);
    }

        .chat-back:hover {
            color: var(--accent);
        }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.25rem;
        background: var(--bg-secondary);
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .bubble-row {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
        position: relative;
    }

        .bubble-row.sent {
            flex-direction: row-reverse;
        }

    .bubble {
        max-width: 65%;
        padding: 0.6rem 0.95rem;
        border-radius: var(--radius-lg);
        font-size: 0.9rem;
        line-height: 1.45;
        word-break: break-word;
        position: relative;
    }

        .bubble.sent {
            background: var(--gradient-primary);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .bubble.received {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
            border-bottom-left-radius: 4px;
        }

        .bubble.deleted {
            opacity: 0.6;
            font-style: italic;
            color: var(--text-muted);
        }

    .bubble-time {
        font-size: 0.68rem;
        color: var(--text-muted);
        flex-shrink: 0;
        margin-bottom: 4px;
    }

    .bubble-edited {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.7);
        margin-left: 0.4rem;
        font-style: italic;
    }

    .bubble.received .bubble-edited {
        color: var(--text-muted);
    }

    .message-menu {
        position: absolute;
        top: -8px;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .bubble-row.sent .message-menu { right: 2px; }
    .bubble-row.received .message-menu { left: -30px; }
    .bubble-row:hover .message-menu { opacity: 1; }

    .menu-btn {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text-muted);
        font-size: 0.75rem;
        transition: var(--transition);
    }

    .menu-btn:hover {
        background: var(--bg-glass);
        color: var(--text-primary);
    }

    .dropdown-menu {
        min-width: 120px;
        font-size: 0.85rem;
    }

    .dropdown-item {
        padding: 0.4rem 0.8rem;
        cursor: pointer;
    }

    .dropdown-item i {
        width: 16px;
        margin-right: 0.5rem;
    }

    .chat-input-area {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-top: none;
        border-radius: 0 0 var(--radius-md) var(--radius-md);
        padding: 0.85rem 1rem;
        display: flex;
        gap: 0.65rem;
        align-items: center;
    }

    #msgInput {
        flex: 1;
        background: var(--bg-input);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        color: var(--text-primary);
        padding: 0.6rem 1.1rem;
        font-size: 0.9rem;
        outline: none;
        transition: var(--transition);
    }

        #msgInput:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

    #sendBtn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--gradient-primary);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: var(--transition);
    }

        #sendBtn:hover {
            transform: scale(1.08);
            box-shadow: var(--shadow-glow);
        }
</style>

<div class="chat-wrapper">
    <!-- Header -->
    <div class="chat-header">
        <img src="@(Model.OtherUserProfilePicture ?? "/images/user.jpg")" alt="@Model.OtherUserName" />
        <div class="chat-header-info">
            <span class="chat-header-name">@Model.OtherUserName</span>
            <span class="online-status" id="onlineStatus">
                <span class="online-dot offline" id="onlineDot"></span>
                <span id="onlineLabel" style="color: var(--text-muted);">Offline</span>
            </span>
        </div>
        <a class="chat-back" asp-controller="Messaging" asp-action="Index">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="messagesContainer">
        @foreach (var msg in Model.History)
        {
            var isSent = msg.SenderId == currentUserId;
            var bubbleClass = isSent ? "sent" : "received";
            if (msg.IsDeleted) { bubbleClass += " deleted"; }
            
            <div class="bubble-row @(isSent ? "sent" : "received")" data-message-id="@msg.Id">
                <span class="bubble-time">@msg.CreatedAt.ToString("HH:mm")</span>
                <div class="bubble @bubbleClass">
                    @if (msg.IsDeleted)
                    {
                        <text>Message deleted</text>
                    }
                    else
                    {
                        @msg.Content
                        @if (msg.IsEdited)
                        {
                            <span class="bubble-edited">(edited)</span>
                        }
                    }
                </div>
                @if (isSent && !msg.IsDeleted)
                {
                    <div class="message-menu dropdown">
                        <button class="menu-btn" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" onclick="editMessage('@msg.Id', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(msg.Content))'); event.stopPropagation();"><i class="fas fa-edit"></i>Edit</a></li>
                            <li><a class="dropdown-item text-danger" onclick="deleteMessage('@msg.Id'); event.stopPropagation();"><i class="fas fa-trash"></i>Delete</a></li>
                        </ul>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Typing indicator -->
    <div class="typing-indicator" id="typingIndicator">
        <span>@Model.OtherUserName is typing</span>
        <div class="typing-dots"><span></span><span></span><span></span></div>
    </div>

    <!-- Input -->
    <div class="chat-input-area">
        @Html.AntiForgeryToken()
        <input type="text" id="msgInput" placeholder="Type a message..." autocomplete="off" />
        <button id="sendBtn" title="Send">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    // ── Constants ────────────────────────────────────────────────────────────
    const currentUserId = "@currentUserId";
    const otherUserId   = "@Model.OtherUserId";

    // ── DOM refs ─────────────────────────────────────────────────────────────
    const container       = document.getElementById("messagesContainer");
    const input           = document.getElementById("msgInput");
    const sendBtn         = document.getElementById("sendBtn");
    const typingIndicator = document.getElementById("typingIndicator");
    const onlineDot       = document.getElementById("onlineDot");
    const onlineLabel     = document.getElementById("onlineLabel");

    // ── Helpers ───────────────────────────────────────────────────────────────
    function scrollToBottom() { container.scrollTop = container.scrollHeight; }
    scrollToBottom();

    function escapeHtml(t) {
        return t.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function getToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
    }

    // ── Bubble renderer ───────────────────────────────────────────────────────
    function appendBubble(senderId, content, sentAt, messageId) {
        const isSent = senderId === currentUserId;
        const time   = new Date(sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const row    = document.createElement("div");
        row.className = `bubble-row ${isSent ? "sent" : "received"}`;
        row.setAttribute('data-message-id', messageId || '');
        
        let menuHtml = '';
        if (isSent && messageId) {
            menuHtml = `
                <div class="message-menu dropdown">
                    <button class="menu-btn" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" onclick="editMessage('${messageId}', '${escapeHtml(content).replace(/'/g, "\\'")}'); event.stopPropagation();"><i class="fas fa-edit"></i>Edit</a></li>
                        <li><a class="dropdown-item text-danger" onclick="deleteMessage('${messageId}'); event.stopPropagation();"><i class="fas fa-trash"></i>Delete</a></li>
                    </ul>
                </div>`;
        }
        
        row.innerHTML = `
            <span class="bubble-time">${time}</span>
            <div class="bubble ${isSent ? "sent" : "received"}">${escapeHtml(content)}</div>
            ${menuHtml}`;
        container.appendChild(row);
        scrollToBottom();
    }

    // ── Online status ─────────────────────────────────────────────────────────
    function setOnline(isOnline) {
        onlineDot.className     = `online-dot ${isOnline ? 'online' : 'offline'}`;
        onlineLabel.textContent = isOnline ? 'Online' : 'Offline';
        onlineLabel.style.color = isOnline ? '#22c55e' : 'var(--text-muted)';
    }
    async function refreshOnlineStatus() {
        try {
            const res  = await fetch(`/Messaging/IsOnline?userId=${encodeURIComponent(otherUserId)}`);
            const data = await res.json();
            setOnline(data.online);
        } catch { /* ignore network errors */ }
    }
    refreshOnlineStatus();
    setInterval(refreshOnlineStatus, 20000); // poll every 20 s as a fallback

    // ── Typing state ──────────────────────────────────────────────────────────
    let typingTimer  = null;
    let isTyping     = false;

    function showTyping() { typingIndicator.style.display = 'flex'; scrollToBottom(); }
    function hideTyping()  { typingIndicator.style.display = 'none'; }

    function stopTypingSignal() {
        if (!isTyping) return;
        isTyping = false;
        clearTimeout(typingTimer);
        connection.invoke("StopTyping", otherUserId).catch(() => {});
    }

    // ── SignalR ───────────────────────────────────────────────────────────────
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .withAutomaticReconnect()
        .build();

    // Single ReceiveDirectMessage handler — renders bubble + auto mark-read
    connection.on("ReceiveDirectMessage", (data) => {
        if (data.senderId !== otherUserId && data.senderId !== currentUserId) return;
        hideTyping();
        appendBubble(data.senderId, data.content, data.sentAt, data.messageId);
        // Auto mark-as-read when the other user's message arrives while we are in this chat
        if (data.senderId === otherUserId) {
            const fd = new FormData();
            fd.append("otherUserId", otherUserId);
            fd.append("__RequestVerificationToken", getToken());
            fetch("/Messaging/MarkRead", { method: "POST", body: fd });
            if (typeof refreshMsgBadge === 'function') refreshMsgBadge();
        }
    });

    // Message edited event
    connection.on("MessageEdited", (data) => {
        console.log("MessageEdited received:", data);
        const row = document.querySelector(`[data-message-id="${data.messageId}"]`);
        console.log("Found row:", row);
        if (row) {
            const bubble = row.querySelector('.bubble');
            console.log("Found bubble:", bubble);
            if (bubble) {
                // Remove deleted class if present
                bubble.classList.remove('deleted');
                bubble.innerHTML = escapeHtml(data.content) + '<span class="bubble-edited">(edited)</span>';
                console.log("Bubble updated with content:", data.content);
            }
        } else {
            console.warn("Could not find message row with ID:", data.messageId);
        }
    });

    // Message deleted event
    connection.on("MessageDeleted", (data) => {
        const row = document.querySelector(`[data-message-id="${data.messageId}"]`);
        if (row) {
            const bubble = row.querySelector('.bubble');
            const menu = row.querySelector('.message-menu');
            if (bubble) {
                bubble.classList.add('deleted');
                bubble.innerHTML = 'Message deleted';
            }
            if (menu) menu.remove();
        }
    });

    // Typing events
    connection.on("UserTyping",        (id) => { if (id === otherUserId) showTyping(); });
    connection.on("UserStoppedTyping", (id) => { if (id === otherUserId) hideTyping(); });

    // Real-time online status pushed by hub on connect/disconnect
    connection.on("UserOnlineStatus",  (id, online) => { if (id === otherUserId) setOnline(online); });

    connection.start().catch(err => console.error("SignalR error:", err));

    // ── Send message ──────────────────────────────────────────────────────────
    async function sendMessage() {
        const content = input.value.trim();
        if (!content) return;
        
        // If we're editing a message, save the edit instead
        if (editingMessageId) {
            await saveEdit(editingMessageId, content);
            return;
        }
        
        input.value = "";
        stopTypingSignal(); // clear typing indicator on the receiver's side

        const fd = new FormData();
        fd.append("receiverId", otherUserId);
        fd.append("content",    content);
        fd.append("__RequestVerificationToken", getToken());

        // POST saves to DB; the controller then broadcasts via SignalR to both parties.
        // We do NOT append a bubble here — the ReceiveDirectMessage handler does that.
        await fetch("/Messaging/SendMessage", { method: "POST", body: fd });

        if (typeof refreshMsgBadge === 'function') refreshMsgBadge();
    }

    // ── Edit message ──────────────────────────────────────────────────────────
    let editingMessageId = null;
    
    function editMessage(messageId, currentContent) {
        const decoded = currentContent.replace(/\\'/g, "'").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&quot;/g, '"').replace(/&amp;/g, "&");
        input.value = decoded;
        input.focus();
        editingMessageId = messageId;
        sendBtn.innerHTML = '<i class="fas fa-check"></i>';
        sendBtn.title = "Save Edit";
    }

    function cancelEdit() {
        editingMessageId = null;
        input.value = "";
        sendBtn.innerHTML = '<i class="fas fa-paper-plane"></i>';
        sendBtn.title = "Send";
    }

    async function saveEdit(messageId, content) {
        const fd = new FormData();
        fd.append("messageId", messageId);
        fd.append("content", content);
        fd.append("__RequestVerificationToken", getToken());
        
        try {
            const res = await fetch("/Messaging/EditMessage", { method: "POST", body: fd });
            if (!res.ok) {
                const error = await res.json();
                alert(error.error || "Failed to edit message");
            }
        } catch (err) {
            console.error("Edit error:", err);
            alert("Failed to edit message");
        }
        
        cancelEdit();
    }

    // ── Delete message ────────────────────────────────────────────────────────
    async function deleteMessage(messageId) {
        if (!confirm("Delete this message?")) return;
        
        const fd = new FormData();
        fd.append("messageId", messageId);
        fd.append("__RequestVerificationToken", getToken());
        
        try {
            const res = await fetch("/Messaging/DeleteMessage", { method: "POST", body: fd });
            if (!res.ok) {
                const error = await res.json();
                alert(error.error || "Failed to delete message");
            }
        } catch (err) {
            console.error("Delete error:", err);
            alert("Failed to delete message");
        }
    }

    // ── Typing detection ──────────────────────────────────────────────────────
    input.addEventListener("input", () => {
        if (!isTyping) {
            isTyping = true;
            connection.invoke("StartTyping", otherUserId).catch(() => {});
        }
        clearTimeout(typingTimer);
        typingTimer = setTimeout(() => {
            isTyping = false;
            connection.invoke("StopTyping", otherUserId).catch(() => {});
        }, 2000); // stop signal after 2 s of inactivity
    });

    // ── Event listeners (each registered exactly once) ────────────────────────
    sendBtn.addEventListener("click", sendMessage);
    input.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
</script>
}

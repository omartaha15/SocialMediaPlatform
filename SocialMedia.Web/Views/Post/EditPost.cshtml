@model SocialMedia.Application.DTOs.PostDtos.UpdatePostDto

@{
    ViewData["Title"] = "Edit Post";
}

<style>
    .edit-post-card {
        background: #242526;
        border: 1px solid #3a3b3c;
        border-radius: 12px;
        padding: 28px 32px;
        max-width: 640px;
        margin: 30px auto;
        box-shadow: 0 4px 24px rgba(0,0,0,.35);
        animation: fadeUp .35s ease both;
    }
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .edit-post-title {
        color: #e4e6eb;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .edit-post-title i { color: #2d88ff; }

    .edit-post-card .form-label {
        color: #b0b3b8;
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 6px;
    }
    .edit-post-card textarea {
        background: #3a3b3c;
        border: 1px solid #4a4b4c;
        border-radius: 10px;
        padding: 14px 16px;
        color: #e4e6eb;
        font-size: 15px;
        min-height: 120px;
        resize: vertical;
        width: 100%;
        transition: border-color .2s;
    }
    .edit-post-card textarea:focus {
        border-color: #2d88ff;
        outline: none;
        box-shadow: 0 0 0 3px rgba(45,136,255,.15);
    }
    .edit-post-card .file-upload-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 6px;
    }
    .edit-post-card .file-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #3a3b3c;
        color: #e4e6eb;
        border-radius: 8px;
        padding: 9px 18px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background .15s;
        border: 1px solid #4a4b4c;
    }
    .edit-post-card .file-label:hover {
        background: #4a4b4c;
    }
    .edit-post-card .file-label i { color: #45bd62; font-size: 16px; }
    .edit-post-card .file-name {
        font-size: 13px;
        color: #b0b3b8;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .current-image-wrap {
        margin-top: 16px;
        border-radius: 10px;
        overflow: hidden;
        background: #1a1a1b;
        border: 1px solid #3a3b3c;
    }
    .current-image-wrap img {
        width: 100%;
        max-height: 300px;
        object-fit: cover;
        display: block;
    }
    .current-image-label {
        font-size: 12px;
        color: #b0b3b8;
        padding: 8px 12px;
        background: #2a2b2c;
    }

    .edit-post-actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
        justify-content: flex-end;
    }
    .btn-edit-save {
        background: linear-gradient(135deg, #2d88ff, #1475eb);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity .15s, transform .1s;
    }
    .btn-edit-save:hover { opacity: .9; }
    .btn-edit-save:active { transform: scale(.97); }
    .btn-edit-cancel {
        background: #3a3b3c;
        color: #e4e6eb;
        border: none;
        border-radius: 8px;
        padding: 10px 22px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: background .15s;
    }
    .btn-edit-cancel:hover { background: #4e4f50; color: #e4e6eb; }

    .text-danger { color: #f85149 !important; }
</style>

<div class="edit-post-card">
    <div class="edit-post-title">
        <i class="fas fa-pen-to-square"></i> Edit Post
    </div>

    <form asp-action="EditPost" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:13px;"></div>

        <div class="mb-3">
            <label class="form-label" for="Content">Content</label>
            <textarea asp-for="Content" id="Content" placeholder="What's on your mind?"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Image</label>
            <div class="file-upload-wrap">
                <label class="file-label" for="edit-image-input">
                    <i class="fas fa-image"></i> Choose Photo
                    <input type="file" name="image" id="edit-image-input" accept="image/*" style="display:none;" />
                </label>
                <span class="file-name" id="edit-file-name"></span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="current-image-wrap">
                <div class="current-image-label"><i class="fas fa-image me-1"></i> Current Image</div>
                <img src="@Model.ImageUrl" alt="Current post image" />
            </div>
        }

        <div class="edit-post-actions">
            <a asp-controller="Home" asp-action="Index" class="btn-edit-cancel">
                <i class="fas fa-arrow-left me-1"></i> Cancel
            </a>
            <button type="submit" class="btn-edit-save">
                <i class="fas fa-check me-1"></i> Save Changes
            </button>
        </div>
    </form>
</div>

<script>
    document.getElementById('edit-image-input')?.addEventListener('change', function () {
        document.getElementById('edit-file-name').textContent = this.files[0]?.name ?? '';
    });
</script>
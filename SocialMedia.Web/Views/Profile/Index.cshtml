@model SocialMedia.Application.DTOs.ProfileDTOs.ProfileDto

@{
    ViewData["Title"] = Model.UserName + " - Profile";
    var coverImg = string.IsNullOrEmpty(Model.CoverPhotoUrl) ? "/images/coverImage.png" : Model.CoverPhotoUrl;
    var profileImg = string.IsNullOrEmpty(Model.ProfilePictureUrl) ? "/images/user.jpg" : Model.ProfilePictureUrl;

    var genderStr = Model.Gender?.ToString();
}


<partial name="_PostStylesPartial" />

<style>
    body {
        background-color: transparent;
    }

    .profile-header-container {
        background: var(--card-bg); border: 1px solid var(--card-border);
        border-bottom-left-radius: 8px;
        border-bottom-right-radius: 8px;
        box-shadow: var(--shadow-sm);
        padding-bottom: 20px;
    }

    .cover-photo-container {
        height: 350px;
        position: relative;
        background-color: #cbced5;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    .cover-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    .edit-cover-btn {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background-color: rgba(255,255,255,0.9);
        font-weight: 600;
        z-index: 2;
    }


    .profile-meta-container {
        display: flex;
        align-items: flex-end;
        padding-left: 30px;
        padding-right: 30px;
        margin-top: -40px;
    }

    .profile-photo-wrapper {
        position: relative;
        z-index: 3;
        margin-right: 20px;
    }

    .profile-photo {
        width: 168px;
        height: 168px;
        border: 4px solid var(--card-bg);
        border-radius: 50%;
        object-fit: cover;
        background-color: var(--card-bg);
        cursor: pointer;
    }

    .profile-camera-icon {
        position: absolute;
        bottom: 10px;
        right: 10px;
        background: linear-gradient(135deg, #2d88ff 60%, #1877f2 100%);
        border-radius: 50%;
        padding: 10px;
        cursor: pointer;
        border: 2px solid #fff;
        box-shadow: 0 2px 8px rgba(24,119,242,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: box-shadow 0.2s, background 0.2s;
    }

        .profile-camera-icon i {
            color: #fff;
            font-size: 1.3rem;
        }

        .profile-camera-icon:hover {
            box-shadow: 0 4px 16px rgba(24,119,242,0.25);
            background: linear-gradient(135deg, #1877f2 80%, #2d88ff 100%);
        }

    .info-card {
        background: var(--card-bg); border: 1px solid var(--card-border);
        border-radius: 8px;
        box-shadow: var(--shadow-sm);
    }

    .info-item {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
        font-size: 15px;
        color: var(--text-primary);
    }

    .info-icon {
        font-size: 20px;
        color: var(--text-muted);
        margin-right: 12px;
        width: 24px;
        text-align: center;
    }

    .details-title {
        color: var(--accent);
    }


    .modal-content {
        background-color: var(--modal-bg);
        border: 1px solid var(--card-border);
    }

        .modal-content input.form-control,
        .modal-content select.form-select {
            color: var(--text-primary) !important;
            background-color: var(--modal-input-bg) !important;
            border: 1px solid var(--modal-input-border);
            font-weight: 500;
        }

            .modal-content input.form-control:focus,
            .modal-content select.form-select:focus {
                background-color: var(--modal-input-bg) !important;
                border-color: var(--accent);
                color: var(--text-primary) !important;
            }

    .btn-light, .btn-secondary, .btn-primary {
        font-weight: 700;
    }

    .btn-secondary {
        background-color: var(--navbar-circle-btn) !important;
        color: var(--text-primary) !important;
        border: 1px solid var(--card-border) !important;
    }

        .btn-secondary:hover {
            background-color: var(--navbar-circle-btn-hover) !important;
        }

    .btn-primary {
        background-color: var(--accent) !important;
        color: #fff !important;
        border: none;
    }

        .btn-primary:hover {
            background-color: var(--accent-hover) !important;
        }

    ::-webkit-calendar-picker-indicator {
        filter: invert(0);
        cursor: pointer;
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show text-center m-0" role="alert" style="border-radius: 0;">
        <strong>Success!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4 mb-5">

    <div class="profile-header-container mx-auto" style="max-width: 900px;">

        <!-- COVER -->
        <div class="cover-photo-container">
            <img src="@coverImg" alt="Cover" class="cover-photo" />
            @if (ViewBag.IsOwner == true)
            {
                <button class="btn btn-light edit-cover-btn shadow-sm" data-bs-toggle="modal" data-bs-target="#coverModal">
                    <i class="bi bi-camera-fill me-1"></i> Edit Cover Photo
                </button>
            }
        </div>

        <!-- PROFILE META (Image + Name + Bio) -->
        <div class="profile-meta-container d-flex justify-content-between">
            <div class="d-flex align-items-end mb-3">
                <!-- PROFILE IMAGE -->
                <div class="profile-photo-wrapper" @if(ViewBag.IsOwner == true) {
                <text>data-bs-toggle="modal" data-bs-target="#profileImageModal"</text>
                                }
>
                    <img src="@profileImg" alt="Profile" class="profile-photo shadow-sm" />
                    @if (ViewBag.IsOwner == true)
                    {
                            <div class="profile-camera-icon shadow-sm">
                                <i class="bi bi-camera-fill fs-5"></i>
                            </div>
                    }
                </div>

                <!-- NAME & BIO -->
                <div class="pb-2">
                    <h1 class="fw-bold mb-0" style="color:var(--text-primary);">@Model.UserName</h1>
                    <a asp-controller="Friendship" asp-action="Index" class="text-decoration-none fw-bold mt-1 mb-2 d-inline-block" style="color: var(--text-secondary);">
                        @ViewBag.FriendsCount Friends
                    </a>
                    @if (!string.IsNullOrEmpty(Model.Bio))
                    {
                        <p class="text-secondary mt-1 mb-0 fs-5">@Model.Bio</p>
                    }
                </div>
            </div>

            <!-- EDIT ACTION -->
            <div class="pb-4">
                @if (ViewBag.IsOwner == true)
                {
                    <button class="btn btn-light fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                        <i class="bi bi-pencil-fill me-1"></i> Edit Profile
                    </button>
                }
                else
                {
                    <a class="btn btn-primary fw-bold shadow-sm"
                       asp-controller="Messaging"
                       asp-action="Chat"
                       asp-route-otherUserId="@Model.Id"
                       asp-route-otherUserName="@Model.UserName"
                       asp-route-otherUserProfilePicture="@Model.ProfilePictureUrl">
                        <i class="bi bi-envelope-fill me-1"></i> Message
                    </a>
                }
            </div>
        </div>

        <hr class="mt-2 mx-4">
    </div>

    <!-- MAIN CONTENT (INFO & POSTS) -->
    <div class="row mx-auto mt-3" style="max-width: 900px;">

        <!-- LEFT COLUMN (INFO) -->
        <div class="col-md-5 ps-0 pr-md-2 mb-3">
            <div class="info-card p-3">
                <h4 class="fw-bold mb-3 details-title">Personal Details</h4>

                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    <div class="info-item">
                        <i class="bi bi-house-door-fill info-icon"></i>
                        <span>Lives in <strong>@Model.Location</strong></span>
                    </div>
                }

                @if (Model.DateOfBirth.HasValue)
                {
                    <div class="info-item">
                        <i class="bi bi-gift-fill info-icon"></i>
                        <span>Born on <strong>@Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")</strong></span>
                    </div>
                }

                @if (Model.Gender != null)
                {
                    <div class="info-item">
                        <i class="bi bi-person-fill info-icon"></i>
                        <span>Gender: <strong>@Model.Gender</strong></span>
                    </div>
                }

                @if (string.IsNullOrEmpty(Model.Location) && !Model.DateOfBirth.HasValue && Model.Gender == null)
                {
                    <p class="text-muted text-center mt-2">No personal details provided yet.</p>
                }

                @if (ViewBag.IsOwner == true)
                {
                    <hr />
                    <!-- Edit Actions inside Details Card -->
                 <button class="btn btn-light w-100 fw-bold mt-2 d-flex align-items-center justify-content-center" data-bs-toggle="modal" data-bs-target="#editProfileModal">
      <i class="bi bi-person-lines-fill me-2 fs-5"></i> Edit Details
  </button>
                    <!-- Change Password Button -->
                    <button class="btn btn-secondary w-100 fw-bold mt-2 d-flex align-items-center justify-content-center" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                        <i class="bi bi-shield-lock-fill me-2 fs-5"></i> Change Password
                    </button>
                }
            </div>
        </div>

        <!-- RIGHT COLUMN (POSTS AREA) -->
        <div class="col-md-7 pe-0">
            @if (ViewBag.IsOwner == true)
            {
                <partial name="_ComposePostPartial" />
            }

            <div class="d-flex align-items-center mb-3 mt-4">
                <i class="bi bi-card-text fs-4 text-secondary me-2"></i>
                <h5 class="fw-bold m-0" style="color:var(--text-primary);">Timeline</h5>
            </div>

            @{
                var userPosts = ViewBag.UserPosts as IEnumerable<SocialMedia.Application.DTOs.PostDtos.PostDto>;
            }

            @if (userPosts != null && userPosts.Any())
            {
                @foreach (var post in userPosts)
                {
                    <partial name="_PostPartial" model="post" />
                }
            }
            else
            {
                <div class="info-card p-4 border-0 text-center text-muted">
                    <div class="empty-icon text-secondary mb-2" style="font-size: 40px;"><i class="bi bi-image"></i></div>
                    <p class="mb-0 fw-bold">No posts yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ================= MODALS ================= -->
<!-- CHANGE PASSWORD MODAL -->
<div class="modal fade" id="changePasswordModal" tabindex="-1">
    <div class="modal-dialog border-0 shadow-lg modal-dialog-centered">
        <form asp-action="ChangePassword" asp-controller="Profile" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold text-light">Change Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @Html.ValidationSummary(true, "", new { @class = "text-danger small mb-3 fw-bold" })

                <label class="form-label text-light small fw-bold">Current Password</label>
                <input name="CurrentPassword" type="password" class="form-control mb-1" placeholder="Enter current password" />
                @Html.ValidationMessage("CurrentPassword", "", new { @class = "text-danger small mb-3 d-block", style = "font-weight: 500;" })

                <label class="form-label text-light small fw-bold">New Password</label>
                <input name="NewPassword" type="password" class="form-control mb-1" placeholder="Enter new password" />
                @Html.ValidationMessage("NewPassword", "", new { @class = "text-danger small mb-3 d-block", style = "font-weight: 500;" })

                <label class="form-label text-light small fw-bold">Confirm New Password</label>
                <input name="ConfirmNewPassword" type="password" class="form-control mb-1" placeholder="Confirm new password" />
                @Html.ValidationMessage("ConfirmNewPassword", "", new { @class = "text-danger small mb-3 d-block", style = "font-weight: 500;" })
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-dark w-100 fw-bold">Update Password</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT PROFILE MODAL -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog border-0 shadow-lg modal-dialog-centered">
        <!--  asp-controller="Profile"  -->
        <form asp-action="Update" asp-controller="Profile" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold text-light">Edit Personal Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <label class="form-label text-light small fw-bold">Name</label>
                <input name="UserName" value="@Model.UserName" class="form-control mb-1" placeholder="Your Name" required />

                @Html.ValidationMessage("UserName", "", new { @class = "text-danger small mb-3 d-block", style = "font-weight: 500;" })

                <label class="form-label text-light small fw-bold">Bio</label>
                <input name="Bio" value="@Model.Bio" class="form-control mb-3" placeholder="Describe yourself..." />

                <label class="form-label text-light small fw-bold">Location</label>
                <input name="Location" value="@Model.Location" class="form-control mb-3" placeholder="Your City" />

                <label class="form-label text-light small fw-bold">Birthday</label>
                <!-- yyyy-MM-dd -->
                <input name="DateOfBirth" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" type="date" class="form-control mb-3" />

                <label class="form-label text-light small fw-bold">Gender</label>
                <select name="Gender" class="form-select mb-2">
                    <option value="">Select Gender</option>
                    @if (Model.Gender == SocialMedia.Domain.Enums.Gender.Male)
                    {
                        <option value="1" selected>Male</option>
                        <option value="2">Female</option>
                    }
                    else if (Model.Gender == SocialMedia.Domain.Enums.Gender.Female)
                    {
                        <option value="1">Male</option>
                        <option value="2" selected>Female</option>
                    }
                    else
                    {
                        <option value="1">Male</option>
                        <option value="2">Female</option>
                    }
                </select>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-primary w-100 fw-bold">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal for who reacted -->
    <div class="modal fade" id="reactorsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background:var(--modal-bg); border:1px solid var(--card-border); border-radius:12px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" style="color:var(--text-primary);">Reactions</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2" id="reactorsList">
                    <!-- Loaded dynamically -->
                </div>
            </div>
        </div>
    </div>

<partial name="_PostStylesPartial" />


<!-- PROFILE IMAGE MODAL -->
<div class="modal fade" id="profileImageModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content p-3 text-center">
            <h5 class="fw-bold mb-3 text-light">Profile Picture</h5>
            <form asp-action="UploadProfileImage" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="file" name="image" class="form-control mb-2"  />
                @Html.ValidationMessage("ProfileImage", "", new { @class = "text-danger small mb-3 d-block", style = "font-weight: 500;" })

                <button type="submit" class="btn btn-primary w-100 fw-bold mb-2">Upload New Picture</button>
            </form>
            <form asp-action="RemoveProfileImage" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger fw-bold w-100 border mt-1">Remove Picture</button>
            </form>
        </div>
    </div>
</div>

<!-- COVER IMAGE MODAL -->
<div class="modal fade" id="coverModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content p-3 text-center">
            <h5 class="fw-bold mb-3 text-light">Cover Photo</h5>
            <form asp-action="UploadCover" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="file" name="image" class="form-control mb-2"  />
                @Html.ValidationMessage("CoverImage", "", new { @class = "text-danger small mb-3 d-block", style = "font-weight: 500;" })

                <button type="submit" class="btn btn-primary w-100 fw-bold mb-2">Upload New Cover</button>
            </form>
            <form asp-action="RemoveCover" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger fw-bold w-100 border mt-1">Remove Cover</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_PostScriptsPartial" />

    <script>
        async function showReactorsModal(postId) {
            const list = document.getElementById("reactorsList");
            if (!list) return;
            list.innerHTML = `<div class="text-center py-3 text-secondary"><i class="fas fa-spinner fa-spin me-2"></i>Loading...</div>`;
            const modal = new bootstrap.Modal(document.getElementById("reactorsModal"));
            modal.show();

            try {
                const response = await fetch(`/Reaction/GetReactors?postId=${postId}`);
                const data = await response.json();
                
                if (!data || data.length === 0) {
                    list.innerHTML = `<div class="text-center py-3 text-secondary">No reactions yet.</div>`;
                    return;
                }

                list.innerHTML = data.map(r => `
                    <div class="reactor-item">
                        <div class="reactor-avatar-wrap">
                            <img src="${r.avatarUrl || '/images/user.jpg'}" class="reactor-avatar" onerror="this.src='/images/user.jpg';" />
                            <span class="reactor-emoji">${emojiMap[r.reactionType] || '👍'}</span>
                        </div>
                        <a href="/Profile/Index/${r.userId}" class="reactor-name text-decoration-none">${r.userName}</a>
                    </div>
                `).join('');
            } catch (err) {
                list.innerHTML = `<div class="text-center py-3 text-danger">Failed to load reactions.</div>`;
            }
        }
    </script>

    <script>

        document.addEventListener("DOMContentLoaded", function() {

            @if (ViewBag.ShowEditModal == true)
            {
                    <text>
                    var editModal = new bootstrap.Modal(document.getElementById('editProfileModal'));
                    editModal.show();
                    </text>
            }

            @if (ViewBag.ShowProfileImageModal == true)
            {
                    <text>
                    var profileImgModal = new bootstrap.Modal(document.getElementById('profileImageModal'));
                    profileImgModal.show();
                    </text>
            }

            @if (ViewBag.ShowCoverModal == true)
            {
                    <text>
                    var coverModal = new bootstrap.Modal(document.getElementById('coverModal'));
                    coverModal.show();
                    </text>
            }

            @if (ViewBag.ShowChangePasswordModal == true)
            {
                    <text>
                    var changePwdModal = new bootstrap.Modal(document.getElementById('changePasswordModal'));
                    changePwdModal.show();
                    </text>
            }

        });
            
       
    </script>
}

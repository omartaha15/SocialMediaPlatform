@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using SocialMedia.Domain.Entities
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zuvo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SocialMedia.Web.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: #18191a;
            color: #e4e6eb;
            font-family: inherit;
        }
        .navbar-fb {
            background-color: #242526 !important;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
            border-bottom: 1px solid #393a3b;
        }
        .navbar-fb .nav-link { color: #b0b3b8 !important; font-weight: 600; padding: 0.5rem 1rem; margin: 0 0.2rem; }
        .navbar-fb .nav-link:hover, .navbar-fb .nav-link.active { color: #2d88ff !important; background-color: #3a3b3c; border-radius: 8px; }
        .navbar-fb .navbar-brand { color: #2d88ff !important; font-weight: 700; font-size: 1.5rem; letter-spacing: -0.5px; }

        .fb-card {
            background: #242526;
            border-radius: 8px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
            border: 1px solid #393a3b;
        }
        .btn-fb-primary {
            background-color: #2d88ff;
            color: white !important;
            border: none;
            font-weight: 600;
            border-radius: 6px;
            transition: background-color 0.2s;
        }
        .btn-fb-primary:hover { background-color: #1475eb; }
        .btn-fb-secondary {
            background-color: #3a3b3c;
            color: #e4e6eb !important;
            border: none;
            font-weight: 600;
            border-radius: 6px;
            transition: background-color 0.2s;
        }
        .btn-fb-secondary:hover { background-color: #4e4f50; }
        .text-fb-muted { color: #b0b3b8 !important; }
        .text-fb-primary { color: #e4e6eb !important; }
        .border, .border-bottom { border-color: #393a3b !important; }
        .list-group-item { background-color: transparent !important; border-color: #393a3b !important; color: inherit; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark fixed-top navbar-fb py-2">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-bolt me-2 text-primary"></i>Zuvo
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        @if (User.Identity.IsAuthenticated == false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn-primary px-3 py-2 rounded-pill ms-2" asp-area="" asp-controller="Account" asp-action="Register"
                                   style="font-size:0.88rem;">
                                    <i class="fas fa-user-plus me-1"></i> Sign Up
                                </a>
                            </li>
                        }
                        else
                        {
                            var userManager = Context.RequestServices.GetRequiredService<UserManager<ApplicationUser>>();
                            var user = await userManager.FindByNameAsync(User.Identity.Name);
                            var profilePic = user?.ProfilePictureUrl ?? "/images/user.jpg";

                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="fas fa-home me-1"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Friendship" asp-action="Index">
                                    <i class="fas fa-user-friends me-1"></i> Friends
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Friendship" asp-action="Suggestions">
                                    <i class="fas fa-compass me-1"></i> Discover
                                </a>
                            </li>
                            
                            <li class="nav-item position-relative">
                                <a class="nav-link" asp-controller="Messaging" asp-action="Index">
                                    <i class="fas fa-envelope"></i>
                                    <span id="msg-badge"
                                          class="badge bg-danger position-absolute"
                                          style="top:4px; right:0; font-size:0.65rem; display:none;">
                                        0
                                    </span>
                                    <span>Messages</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="GroupChat" asp-action="Index">
                                    <i class="fas fa-users"></i>
                                    <span>Groups</span>

                                </a>
                            </li>
                            <li class="nav-item ms-2 d-flex align-items-center">
                                <a asp-controller="Profile" asp-action="Index" class="d-flex align-items-center text-decoration-none text-dark">
                                    <img src="@profilePic" class="rounded-circle me-2" style="width:36px; height:36px; object-fit:cover;" />
                                    <span>@User.Identity.Name</span>
                                </a>
                            </li>
                            <li class="nav-item ms-1">
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link btn btn-link" style="border:none; cursor:pointer;">
                                        <i class="fas fa-sign-out-alt me-1"></i> Logout
                                    </button>
                                </form>
                            </li>
                                
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container" style="padding-top: 80px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
